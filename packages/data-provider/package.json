    "dev": "tsup --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@athena/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
